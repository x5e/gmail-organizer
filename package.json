{
  "name": "gmail-organizer-mcp",
  "version": "1.0.0",
  "description": "Remote MCP server providing Gmail read and label-management capabilities to Claude",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "docker compose up -d && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx src/db/migrate.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.2.2",
    "@modelcontextprotocol/sdk": "^1.15.0",
    "fastify": "^5.3.2",
    "jose": "^6.2.2",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@vitest/coverage-v8": "^3.0.5",
    "msw": "^2.7.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
