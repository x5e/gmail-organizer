# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# 32-byte AES-256-GCM encryption key, base64-encoded
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=your-32-byte-base64-encoded-key-here

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/gmail_organizer

# Public base URL of this server (used for OAuth callback construction)
BASE_URL=https://your-domain.com

# Server port (default: 3000)
PORT=3000

# Log level: trace, debug, info, warn, error (default: info)
LOG_LEVEL=info
